<style type="text/css">
  

  body {
  background-color: #000;
  font-family: 'Arial', sans-serif;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  flex-direction: column;
}

.container {
  background: #111;
  padding: 30px;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
  width: 50%;
  text-align: center;
}

h1 {
  font-size: 28px;
  color: #fff;
  margin-bottom: 10px;
}

p {
  font-size: 16px;
  color: #ccc;
}

h2 {
  font-size: 22px;
  color: #fff;
  margin-top: 20px;
  border-bottom: 2px solid #555;
  padding-bottom: 5px;
}

form {
  background: #222;
  padding: 20px;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

p {
  margin: 10px 0;
  text-align: center;
}

.rating-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

input[type="number"] {
  width: 50px;
  padding: 5px;
  border: 1px solid #888;
  border-radius: 5px;
  background: #333;
  color: #fff;
  text-align: center;
}

input[type="submit"] {
  background: #fff;
  color: #000;
  border: none;
  padding: 10px 20px;
  font-size: 16px;
  border-radius: 5px;
  cursor: pointer;
  transition: background 0.3s ease, color 0.3s ease;
  margin-top: 10px;
}

input[type="submit"]:hover {
  background: #888;
  color: #fff;
}

</style>



<h1><%= @store.name %></h1>
<p>Address: <%= @store.address %></p>
<p>Overall Rating: <%= @store.overall_rating.round(1) %></p>

<h2>Submit Your Rating</h2>
<%= form_for [@store, @rating || @store.ratings.new], method: (@rating ? :patch : :post) do |f| %>
  <p>Rating: <%= f.number_field :score, in: 1..5 %></p>
  <p><%= f.submit "Submit Rating" %></p>
<% end %>
