<style>
  body {
  background-color: #000;
  font-family: 'Arial', sans-serif;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  flex-direction: column;
}

.container {
  background: #111;
  padding: 30px;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
  width: 50%;
  text-align: center;
}

h1 {
  font-size: 28px;
  color: #fff;
  margin-bottom: 10px;
}

h2 {
  font-size: 22px;
  color: #fff;
  margin-top: 20px;
  border-bottom: 2px solid #555;
  padding-bottom: 5px;
}

p {
  font-size: 16px;
  color: #ccc;
}

ul {
  list-style: none;
  padding: 0;
}

li {
  background: #222;
  margin: 10px 0;
  padding: 15px;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(255, 255, 255, 0.1);
  text-align: center;
}

a {
  color: #fff;
  text-decoration: none;
  font-weight: bold;
  transition: color 0.3s ease;
}

a:hover {
  color: #aaa;
}

form {
  background: #222;
  padding: 20px;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.rating-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

input[type="number"] {
  width: 50px;
  padding: 5px;
  border: 1px solid #888;
  border-radius: 5px;
  background: #333;
  color: #fff;
  text-align: center;
}

input[type="submit"] {
  background: #fff;
  color: #000;
  border: none;
  padding: 10px 20px;
  font-size: 16px;
  border-radius: 5px;
  cursor: pointer;
  transition: background 0.3s ease, color 0.3s ease;
  margin-top: 10px;
}

input[type="submit"]:hover {
  background: #888;
  color: #fff;
}

</style>






<h1>Welcome to Store Rating App</h1>

<h2>Newly Added Stores</h2>
<ul>
  <% @stores.each do |store| %>
    <li>
<strong><%= link_to store.name, store_path(store.id) %></strong>
<p><%= store.description || "No description available" %></p>
    </li>
  <% end %>
</ul>

<h2>Top Rated Stores</h2>
<ul>
  <% @top_rated_stores.each do |store| %>
    <li>
<strong><%= link_to store.name, store_path(store.id) %></strong>
Avg Rating: <%= store.ratings.average(:value)&.round(2) || "No ratings yet" %>
    </li>
  <% end %>
</ul>
